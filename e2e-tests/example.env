# REMOVE THE TRAILING /TEXTS FROM THESE URLS
SANDBOX_URL=<https://my-localhost-or-cauldron-or-prod.com/>
SANDBOX_URL_IL=<https://my-localhost-or-cauldron-il-or-prod.com/>

# Each of the accounts below is logged in once at the start of every test run
# by e2e-tests/global-setup.ts, which writes a storage-state file per profile
# (auth_english_user.json, auth_english_admin.json, etc.). Individual tests
# read those files; they never log in themselves. If a PLAYWRIGHT_*_EMAIL /
# _PASSWORD pair is missing, globalSetup skips that account with a warning and
# any test using it throws a clear "auth file missing" error.

PLAYWRIGHT_USER_EMAIL="<user@example.org>"
PLAYWRIGHT_USER_PASSWORD="<password>"

# User with admin access that can trigger certain backstage api calls
PLAYWRIGHT_SUPERUSER_EMAIL="<admin@example.org>"
PLAYWRIGHT_SUPERUSER_PASSWORD="<password>"


# User with Library Assistant Access. Used for automation tests on Library Assistant (English).
PLAYWRIGHT_LA_USER_EMAIL="<la-user@example.org>"
PLAYWRIGHT_LA_USER_PASSWORD="<password>"

# Separate Library-Assistant account whose account Site-Language is set to HEBREW.
# Required for the Hebrew LA suite (e2e-tests/assistant/library-assistant-hebrew.spec.ts):
# a logged-in user is routed to their account-language's domain, so the Hebrew LA
# tests need an account that lives on www.sefaria.org.il. global-setup logs it in
# natively on the .org.il domain. See assistant/README.md §12.
PLAYWRIGHT_LA_USER_HE_EMAIL="<la-user-hebrew@example.org>"
PLAYWRIGHT_LA_USER_HE_PASSWORD="<password>"

# Multiplier for all timeout values (0.1 to 3.0, default 1.0)
# Use values > 1.0 for slower environments, < 1.0 for faster ones
TIMEOUT_MULTIPLIER=1.0